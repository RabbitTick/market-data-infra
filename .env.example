# Container images
INGEST_IMAGE=ghcr.io/rabbittick/market-ingest-streamer:
PERSISTER_IMAGE=ghcr.io/rabbittick/market-data-persister:

# Ports
INGEST_PORT=8081
PERSISTER_PORT=8080
RABBITMQ_AMQP_PORT=5672
RABBITMQ_UI_PORT=15672
MYSQL_PORT=3306
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Credentials
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=rabbittick
MYSQL_USER=app
MYSQL_PASSWORD=
RABBITMQ_DEFAULT_USER=
RABBITMQ_DEFAULT_PASS=
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# Backup
BACKUP_RETAIN_DAYS=7

# App tuning
TZ=Asia/Seoul